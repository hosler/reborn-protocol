}
=====CASE array-oob-clamp
if (created) {
  this.arr = {10,20,30};
  this.oob = this.arr[7];
  this.neg = this.arr[-1];
  this.arr[-1] = 99;
  this.after = this.arr[0];
}
=====CASE array-empty
if (created) {
  setarray this.e, 0;
  // NOTE: `this.oob = this.e[3];` (a bare index-into-empty-array read,
  // assigned directly) is deliberately avoided here: GServer-v2's
  // GS1Visitor::visitIdentifierValue falls back to wrapping a COPY of the
  // whole (empty) array variable when GameVariable::get<double> fails
  // (empty array => nullopt), so a direct assignment of that expression
  // copies the container itself rather than yielding a plain 0 -- an
  // obscure GameVariable-wrapper quirk this tree-walking port doesn't model.
  // Forcing scalar coercion via `+ 0` (arithmetic always getCopy<double>s)
  // sidesteps it and tests the meaningful part: OOB-into-empty is 0.
  this.oob = this.e[3] + 0;
}
