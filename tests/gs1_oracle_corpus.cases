=====CASE truthiness-number
if (created) {
  this.n5 = 0; if (5) this.n5 = 1;
  this.n0 = 0; if (0) this.n0 = 1;
  this.and = 5 && 2;
  this.or = 5 || 2;
  this.notzero = !0;
  this.not42 = !42;
}
=====CASE truthiness-string
if (created) {
  // NOTE: a bare `#s(x)` message code used directly as a condition/RHS is
  // NOT the same as reading the variable itself -- confirmed empirically
  // against the oracle: `if (#s(this.s))` is false even for a non-empty
  // this.s, and `this.v = #s(this.s);` doesn't even store "hello" in this.v
  // ('=' assignment always numeric-coerces its RHS, GS1Visitor.cpp
  // visitStatementAssignment; only `setstring` truly stores text). A bare
  // variable reference (`if (this.s)`) is the real, working flag-truthiness
  // idiom, so that's what this case tests.
  setstring this.s,hello;
  this.full = 0; if (this.s) this.full = 1;
  setstring this.blank,;
  this.empty = 0; if (this.blank) this.empty = 1;
  this.strcond = 0; if (strequals(#s(this.s),hello)) this.strcond = 1;
}
=====CASE epsilon-equality
if (created) {
  this.close = (0.10001 == 0.1);
  this.far = (0.101 == 0.1);
  this.ne = (0.10001 != 0.1);
  this.lt = (0.10001 < 0.1);
  this.gt = (0.10001 > 0.1);
}
